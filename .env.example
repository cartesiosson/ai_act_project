# ============================================================================
# AI Act Compliance Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# ============================================================================

# ============================================================================
# ONTOLOGY CONFIGURATION
# ============================================================================
CURRENT_RELEASE=1.0.0

# ============================================================================
# FUSEKI (RDF TRIPLESTORE) CONFIGURATION
# ============================================================================
# SECURITY: las credenciales "admin/admin" son SOLO para desarrollo local.
# Cámbialas obligatoriamente antes de cualquier despliegue accesible en red.
FUSEKI_ENDPOINT=http://fuseki:3030
FUSEKI_USER=admin
FUSEKI_PASSWORD=admin
FUSEKI_DATASET=ds
FUSEKI_GRAPH=http://ai-act.eu/ontology
FUSEKI_GRAPH_DATA=http://ai-act.eu/ontology/data
FUSEKI_ADMIN_PASSWORD=admin

# ============================================================================
# MONGODB CONFIGURATION
# ============================================================================
MONGO_URL=mongodb://mongo:27017
MONGO_PORT=27017

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================
ONTOLOGY_PATH=/ontologias/ontologia-v${CURRENT_RELEASE}.ttl
REASONER_SERVICE_URL=http://reasoner:8000
BACKEND_PORT=8000
# Orígenes CORS permitidos (lista separada por comas). En producción restríngelo
# a los dominios reales del frontend, p. ej. https://seramis.example.org
ALLOWED_ORIGINS=http://localhost:5173

# ============================================================================
# REASONER SERVICE CONFIGURATION
# ============================================================================
REASONER_PORT=8001

# ============================================================================
# FORENSIC AGENT CONFIGURATION
# ============================================================================
FORENSIC_PORT=8002
# LLM Provider: only "ollama" (local) is implemented in v1.0.
# "anthropic" (cloud / Claude) is planned on the roadmap but NOT yet wired into the code.
LLM_PROVIDER=ollama
# Reserved for the planned Anthropic Claude integration (currently unused):
ANTHROPIC_API_KEY=your_api_key_here
# For Ollama (local LLM):
OLLAMA_ENDPOINT=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ============================================================================
# MCP SPARQL SERVER CONFIGURATION
# ============================================================================
MCP_PORT=8080

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
NODE_ENV=development
FRONTEND_PORT=5173
VITE_FUSEKI_URL=http://localhost:3030/ds/sparql
VITE_FUSEKI_USER=admin
VITE_FUSEKI_PASSWORD=admin
VITE_API_URL=http://localhost:8000
# URL base de la documentación de la ontología (servicio nginx "ontologias")
VITE_DOCS_URL=http://localhost/docs

# ============================================================================
# ONTOLOGIES SERVICE (NGINX) CONFIGURATION
# ============================================================================
ONTOLOGIES_PORT=80

# ============================================================================
# DOCKER IMAGES
# ============================================================================
FUSEKI_IMAGE=stain/jena-fuseki
MONGO_IMAGE=mongo:6
